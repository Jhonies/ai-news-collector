# ============================================================
#  .env.exemplo — Template de configuração do AI News Collector
#  Copie este arquivo: cp .env.exemplo .env
#  Edite o .env com seus valores. NUNCA commite o .env.
# ============================================================

# Modelo Ollama a usar (deve estar baixado localmente)
# Opções: phi3 (~2.3GB), gemma2:2b (~1.6GB), llama3 (~4.7GB), mistral (~4.1GB)
OLLAMA_MODEL=phi3:latest

# Caminho do banco de dados SQLite
DB_PATH=./data/news.db

# Quantidade máxima de notícias por execução
MAX_NOTICIAS=12

# Fontes RSS personalizadas (separadas por vírgula — sem espaços)
# Deixe vazio para usar as fontes padrão do collector.py
SOURCES_RSS=

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
